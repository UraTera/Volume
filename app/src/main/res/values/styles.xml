<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AppCompat.Transparent.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Активирует полупрозрачный режим -->
        <item name="android:windowIsTranslucent">true</item>
        <!-- Задаёт прозрачный фон окна -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!-- Накладывается на передний план области содержимого окна -->
        <item name="android:windowContentOverlay">@null</item>
        <!-- Убирает заголовок (кнопку «Назад» и т.п.) -->
        <item name="android:windowNoTitle">true</item>
        <!-- Позволяет окну «плавать» поверх других  -->
        <item name="android:windowIsFloating">true</item>
        <!-- Отключает затемнение фона за окном -->
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="buttons">
        <item name="android:layout_width">180dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/rectangle_black</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:layout_marginStart">0dp</item>
        <item name="android:layout_marginEnd">0dp</item>
    </style>

    <style name="buttons.ok">
        <item name="android:layout_width">120dp</item>
    </style>

    <style name="view">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginEnd">40dp</item>
        <item name="android:layout_marginStart">0dp</item>
    </style>

    <style name="view.top">
        <item name="android:background">@drawable/rectangle_black</item>
    </style>

    <style name="lines">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="frame">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="card">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="radio_button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
    </style>


</resources>